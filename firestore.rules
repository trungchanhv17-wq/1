rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User Profile Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && incoming().uid == userId
        && incoming().email is string
        && incoming().displayName is string
        && incoming().xp is number
        && incoming().streak is number
        && incoming().level is string
        && incoming().hearts is number
        && incoming().completedLessons is list
        && incoming().premiumStatus is bool
        && incoming().createdAt == request.time
        && incoming().lastActive == request.time;
        
      allow update: if isOwner(userId)
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && (
          // Action: Update Stats
          incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'streak', 'level', 'hearts', 'completedLessons', 'lastActive', 'photoURL', 'displayName'])
          || incoming().diff(existing()).affectedKeys().hasOnly(['lastActive'])
        )
        && incoming().lastActive == request.time;
    }
  }
}
